{
  "name": "Showcase",
  "type": "object",
  "properties": {
    "lead_id": {
      "type": "string",
      "description": "ID of the lead"
    },
    "full_name": {
      "type": "string",
      "description": "Attendee name"
    },
    "email": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "showcase_type": {
      "type": "string",
      "enum": [
        "diploma_showcase",
        "diamond_showcase"
      ],
      "description": "Type of showcase"
    },
    "showcase_date": {
      "type": "string",
      "format": "date-time",
      "description": "When is the showcase"
    },
    "registration_date": {
      "type": "string",
      "format": "date-time"
    },
    "attendance_status": {
      "type": "string",
      "enum": [
        "registered",
        "attended",
        "no_show"
      ],
      "default": "registered"
    },
    "purchased": {
      "type": "boolean",
      "default": false,
      "description": "Did they buy?"
    },
    "product_bought": {
      "type": "string",
      "description": "What did they buy (Diploma/Diamond)"
    },
    "amount_paid": {
      "type": "number",
      "description": "How much they paid"
    },
    "came_from": {
      "type": "string",
      "enum": [
        "silver_buyer",
        "diploma_buyer",
        "outside_lead"
      ],
      "description": "Where they came from"
    },
    "follow_up_status": {
      "type": "string",
      "enum": [
        "pending",
        "offer_sent",
        "called",
        "not_interested"
      ],
      "default": "pending",
      "description": "For non-buyers follow-up"
    },
    "special_offer_sent": {
      "type": "boolean",
      "default": false
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "full_name",
    "phone",
    "showcase_type",
    "showcase_date"
  ]
}