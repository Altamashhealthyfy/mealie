{
  "name": "MealPlan",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string",
      "description": "ID of the client this plan is for"
    },
    "name": {
      "type": "string",
      "description": "Name of the meal plan"
    },
    "plan_tier": {
      "type": "string",
      "enum": [
        "basic",
        "advanced"
      ],
      "default": "basic",
      "description": "Basic (RDA/Calorie-based) or Advanced (Disease Reversal)"
    },
    "disease_focus": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "diabetes_reversal",
          "hypertension_control",
          "pcos_management",
          "thyroid_balance",
          "fatty_liver_reversal",
          "cholesterol_management",
          "gut_health",
          "hormonal_balance",
          "autoimmune_support",
          "general_wellness"
        ]
      },
      "description": "For advanced plans - specific disease focus areas"
    },
    "duration": {
      "type": "number",
      "description": "Duration in days"
    },
    "meal_pattern": {
      "type": "string",
      "enum": [
        "daily",
        "3-3-4"
      ],
      "description": "Meal plan pattern"
    },
    "target_calories": {
      "type": "number",
      "description": "Daily calorie target"
    },
    "meals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "day": {
            "type": "number"
          },
          "meal_type": {
            "type": "string"
          },
          "meal_name": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "portion_sizes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "calories": {
            "type": "number"
          },
          "protein": {
            "type": "number"
          },
          "carbs": {
            "type": "number"
          },
          "fats": {
            "type": "number"
          },
          "nutritional_tip": {
            "type": "string"
          },
          "mpess_benefit": {
            "type": "string",
            "description": "How this meal supports Mind/Physical/Emotional/Social/Spiritual wellness"
          }
        }
      }
    },
    "food_preference": {
      "type": "string",
      "enum": [
        "veg",
        "non_veg",
        "jain",
        "mixed"
      ]
    },
    "regional_preference": {
      "type": "string",
      "enum": [
        "north",
        "south",
        "west",
        "east",
        "all"
      ]
    },
    "mpess_integration": {
      "type": "object",
      "description": "MPESS wellness guidance with the meal plan",
      "properties": {
        "mind_practices": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Daily mind wellness practices"
        },
        "physical_practices": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Daily physical wellness practices"
        },
        "emotional_practices": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Daily emotional wellness practices"
        },
        "social_practices": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Daily social wellness practices"
        },
        "spiritual_practices": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Daily spiritual wellness practices"
        }
      }
    },
    "advanced_protocols": {
      "type": "object",
      "description": "For advanced disease reversal plans",
      "properties": {
        "fasting_protocol": {
          "type": "string"
        },
        "supplement_guidance": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lifestyle_modifications": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "monitoring_parameters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected_outcomes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "precautions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Whether this is the active meal plan"
    }
  },
  "required": [
    "name",
    "duration",
    "meals"
  ]
}