{
  "name": "Client",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "Client's full name"
    },
    "email": {
      "type": "string",
      "description": "Client's email"
    },
    "phone": {
      "type": "string",
      "description": "Client's phone number"
    },
    "business_vertical": {
      "type": "string",
      "enum": [
        "health_coach_training",
        "health_disease_management",
        "prosperity_program"
      ],
      "description": "Which vertical they belong to"
    },
    "client_type": {
      "type": "string",
      "enum": [
        "health_client",
        "health_coach_student",
        "prosperity_student"
      ],
      "description": "Type of client"
    },
    "current_program": {
      "type": "string",
      "description": "Current program they're enrolled in"
    },
    "programs_completed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of completed programs"
    },
    "upgrade_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from_program": {
            "type": "string"
          },
          "to_program": {
            "type": "string"
          },
          "upgrade_date": {
            "type": "string",
            "format": "date"
          },
          "amount": {
            "type": "number"
          }
        }
      },
      "description": "History of all upgrades"
    },
    "total_spent": {
      "type": "number",
      "default": 0,
      "description": "Total lifetime value"
    },
    "age": {
      "type": "number"
    },
    "gender": {
      "type": "string",
      "enum": [
        "male",
        "female",
        "other"
      ]
    },
    "height": {
      "type": "number",
      "description": "Height in cm"
    },
    "weight": {
      "type": "number",
      "description": "Current weight in kg"
    },
    "initial_weight": {
      "type": "number",
      "description": "Starting weight in kg"
    },
    "target_weight": {
      "type": "number",
      "description": "Target weight in kg"
    },
    "activity_level": {
      "type": "string",
      "enum": [
        "sedentary",
        "lightly_active",
        "moderately_active",
        "very_active",
        "extremely_active"
      ]
    },
    "goal": {
      "type": "string",
      "enum": [
        "weight_loss",
        "weight_gain",
        "maintenance",
        "muscle_gain",
        "health_improvement",
        "disease_reversal"
      ]
    },
    "health_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "diabetes_type1",
          "diabetes_type2",
          "prediabetes",
          "hypertension",
          "pcos",
          "thyroid_hypo",
          "thyroid_hyper",
          "fatty_liver",
          "high_cholesterol",
          "ibs",
          "gerd",
          "autoimmune",
          "hormonal_imbalance",
          "insulin_resistance",
          "metabolic_syndrome",
          "none"
        ]
      },
      "description": "Diagnosed health conditions"
    },
    "current_medications": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of current medications"
    },
    "lab_reports": {
      "type": "object",
      "description": "Latest lab test results",
      "properties": {
        "hba1c": {
          "type": "number",
          "description": "HbA1c level"
        },
        "fasting_glucose": {
          "type": "number"
        },
        "pp_glucose": {
          "type": "number",
          "description": "Post-prandial glucose"
        },
        "total_cholesterol": {
          "type": "number"
        },
        "ldl": {
          "type": "number"
        },
        "hdl": {
          "type": "number"
        },
        "triglycerides": {
          "type": "number"
        },
        "tsh": {
          "type": "number"
        },
        "vitamin_d": {
          "type": "number"
        },
        "vitamin_b12": {
          "type": "number"
        },
        "hemoglobin": {
          "type": "number"
        },
        "sgot": {
          "type": "number"
        },
        "sgpt": {
          "type": "number"
        }
      }
    },
    "food_preference": {
      "type": "string",
      "enum": [
        "veg",
        "non_veg",
        "jain",
        "mixed"
      ]
    },
    "regional_preference": {
      "type": "string",
      "enum": [
        "north",
        "south",
        "west",
        "east",
        "all"
      ]
    },
    "medical_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Any medical conditions or health issues"
    },
    "allergies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Food allergies or intolerances"
    },
    "medications": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bmr": {
      "type": "number"
    },
    "tdee": {
      "type": "number"
    },
    "target_calories": {
      "type": "number"
    },
    "target_protein": {
      "type": "number"
    },
    "target_carbs": {
      "type": "number"
    },
    "target_fats": {
      "type": "number"
    },
    "plan_tier_eligible": {
      "type": "string",
      "enum": [
        "basic",
        "advanced"
      ],
      "default": "basic",
      "description": "Which tier of plan they're eligible for"
    },
    "mpess_assessment": {
      "type": "object",
      "description": "Initial MPESS wellness assessment",
      "properties": {
        "mind_score": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        },
        "physical_score": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        },
        "emotional_score": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        },
        "social_score": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        },
        "spiritual_score": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        },
        "overall_wellness": {
          "type": "number",
          "minimum": 1,
          "maximum": 10
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "completed"
      ],
      "default": "active"
    },
    "join_date": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string",
      "description": "Dietitian's notes about the client"
    },
    "dietitian_id": {
      "type": "string",
      "description": "ID of the assigned dietitian (team_admin or student_coach)"
    },
    "owner_id": {
      "type": "string",
      "description": "ID of the coach who owns this client (for data isolation)"
    }
  },
  "required": [
    "full_name",
    "email"
  ]
}