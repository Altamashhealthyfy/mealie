{
  "name": "ProgressLog",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string",
      "description": "ID of the client"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "weight": {
      "type": "number",
      "description": "Weight in kg"
    },
    "measurements": {
      "type": "object",
      "properties": {
        "chest": {
          "type": "number"
        },
        "waist": {
          "type": "number"
        },
        "hips": {
          "type": "number"
        },
        "arms": {
          "type": "number"
        },
        "thighs": {
          "type": "number"
        }
      }
    },
    "photos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs of progress photos"
    },
    "notes": {
      "type": "string",
      "description": "Progress notes"
    },
    "energy_level": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "sleep_quality": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "stress_level": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "meal_adherence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Percentage of meal plan followed"
    }
  },
  "required": [
    "client_id",
    "date"
  ]
}