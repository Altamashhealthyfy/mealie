{
  "name": "MealPlanTemplate",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Template name (e.g., Veg Weight Loss 1500cal)"
    },
    "description": {
      "type": "string",
      "description": "What this template is for"
    },
    "category": {
      "type": "string",
      "enum": [
        "weight_loss",
        "weight_gain",
        "diabetes",
        "pcos",
        "thyroid",
        "maintenance",
        "muscle_gain",
        "general"
      ],
      "description": "Template category"
    },
    "duration": {
      "type": "number",
      "description": "Duration in days"
    },
    "target_calories": {
      "type": "number",
      "description": "Daily calorie target"
    },
    "food_preference": {
      "type": "string",
      "enum": [
        "veg",
        "non_veg",
        "jain",
        "mixed"
      ]
    },
    "regional_preference": {
      "type": "string",
      "enum": [
        "north",
        "south",
        "west",
        "east",
        "all"
      ]
    },
    "meals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "day": {
            "type": "number"
          },
          "meal_type": {
            "type": "string"
          },
          "meal_name": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "portion_sizes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "calories": {
            "type": "number"
          },
          "protein": {
            "type": "number"
          },
          "carbs": {
            "type": "number"
          },
          "fats": {
            "type": "number"
          },
          "nutritional_tip": {
            "type": "string"
          }
        }
      }
    },
    "is_public": {
      "type": "boolean",
      "default": false,
      "description": "Available to all coaches in marketplace"
    },
    "times_used": {
      "type": "number",
      "default": 0,
      "description": "How many times this template was used"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for searching templates"
    }
  },
  "required": [
    "name",
    "meals",
    "target_calories"
  ]
}